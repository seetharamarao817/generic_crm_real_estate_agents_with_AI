FLASK_APP=backend.app
FLASK_ENV=development
FLASK_RUN_PORT=5000

# OpenRouter configuration
OPENROUTER_API_KEY="sk-or-v1-e2b"
OPENROUTER_MODELS="qwen/qwen3.6-plus:free,openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free"

# Hugging Face fallback configuration
HF_FALLBACK_MODELS="Qwen/Qwen2.5-0.5B-Instruct","QA"

# Document pipeline chunking options
CHUNK_SIZE="500"
CHUNK_OVERLAP="50"
# Strategy can be 'sentence' or 'fixed'
CHUNK_STRATEGY="fixed"

# Chroma DB Path
CHROMA_DB_DIR="./chroma_db"
UPLOADS_DIR="./uploads"
